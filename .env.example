Database Configuration
MONGODB_URI=mongodb+srv://FBPADB:FBPA2020@cluster0.fvycshx.mongodb.net/fbpa-db?appName=Cluster0
# Authentication
JWT_SECRET=9b6cfa8e4e7e9c74f3aef3c69c2b9e43b6e1f98c0c2c6d8f9a1b2c3d4e5f6a7
JWT_EXPIRES_IN=1h

# Server Configuration
PORT=4000

# CORS Configuration (comma-separated list of allowed origins)
# Make sure to include all domains that need access, e.g.:
CORS_ORIGIN=https://hdhtransport.com, https://www.hdhtransport.com, https://express-git-fbpa-josephmabbinante-a11ys-projects.vercel.app

# Optional: Static file serving (set to 'true' if serving React build from this server)
SERVE_STATIC=true

# Frontend build configuration (used by Vite at BUILD TIME — baked into the JS bundle).
# • Same-service Railway deployment (frontend + backend on one Railway service):
#   Leave VITE_API_URL empty or unset. The React app will use relative /api/* paths
#   which hit the same Express server — no CORS, no URL needed.
# • Separate deployments (e.g. Vercel frontend → Railway backend):
#   Set this to the full Railway backend URL including https://, e.g.:
#   VITE_API_URL=https://fbpa-api-production.up.railway.app
VITE_API_URL=https://mongodb-production-cf05.up.railway.app/

# Optional: Email/SMTP Configuration (for sending notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@audit-iq.com
