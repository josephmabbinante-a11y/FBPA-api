# Frontend mock mode is controlled by VITE_MOCK_MODE and VITE_USE_MOCK_API in fbpa-ui/.env
# When USE_MOCK_API is disabled on the frontend, it will call this backend.
# Ensure MONGODB_URI is set and the database is running before disabling mock mode.

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/fbpa

# Authentication
JWT_SECRET=your-secret-here-at-least-32-chars
JWT_EXPIRES_IN=1h

# CORS Configuration (comma-separated list of allowed origins)
# Make sure to include all domains that need access, e.g.:
CORS_ORIGIN=http://localhost:5173

# Optional: Static file serving (set to 'true' if serving React build from this server)
SERVE_STATIC=false


# Optional: Email/SMTP Configuration (for sending notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@audit-iq.com
