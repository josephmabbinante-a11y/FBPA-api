# Database Configuration
# Get this from MongoDB Atlas: Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/fbpa-db?retryWrites=true&w=majority

# Authentication
# Must be at least 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=1h

# Server Configuration
PORT=3000

# CORS Configuration (comma-separated list of allowed origins)
# Include all domains that need access to this API
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Optional: Static file serving (set to 'true' if serving React build from this server)
SERVE_STATIC=false

# Frontend build configuration (used by Vite; set to the backend API URL for production builds)
VITE_API_URL=https://fbpa-api-production.up.railway.app

# Optional: Email/SMTP Configuration (for sending notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@your-domain.com
