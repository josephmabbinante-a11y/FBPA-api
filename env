Database Configuration
MONGODB_URI=<your-mongodb-connection-string>
# Authentication
JWT_SECRET=<your-jwt-secret-minimum-32-characters>
JWT_EXPIRES_IN=8h

# Server Configuration
PORT=4000

# CORS Configuration (comma-separated list of allowed origins)
# Make sure to include all domains that need access, e.g.:
CORS_ORIGIN=https://hdhtransport.com, https://www.hdhtransport.com, https://express-git-fbpa-josephmabbinante-a11ys-projects.vercel.app

# Optional: Static file serving (set to 'true' if serving React build from this server)
SERVE_STATIC=true

# Frontend build configuration (used by Vite; set to the backend API URL for production builds)
VITE_API_URL=https://fbpa-api-production.up.railway.app/

# Optional: Email/SMTP Configuration (for sending notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@audit-iq.com
